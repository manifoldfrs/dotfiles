#!/usr/bin/env bash

set -e

SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
SOURCE="$SCRIPT_DIR/../share/spotify-visualizer/spotify-visualizer.ts"

if command -v tsx > /dev/null 2>&1; then
    exec tsx "$SOURCE" "$@"
fi

if command -v npx > /dev/null 2>&1; then
    exec npx -y tsx "$SOURCE" "$@"
fi

echo "spotify-visualizer requires Node.js with tsx. Install with: npm install -g tsx" >&2
exit 1
