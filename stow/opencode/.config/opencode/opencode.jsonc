{
        "$schema": "https://opencode.ai/config.json",
        "autoupdate": true,
        "mcp": {
                "RepoPrompt": {
                        "type": "local",
                        "command": [
                                "/Applications/RepoPrompt.app/Contents/MacOS/repoprompt-mcp"
                        ],
                        "enabled": true,
                        "timeout": 3600000,
                },
                "ref": {
                        "type": "remote",
                        "url": "https://api.ref.tools/mcp?apiKey={env:REF_API_KEY}",
                        "enabled": true,
                        "timeout": 10000,
                },
                "exa": {
                        "type": "remote",
                        "url": "https://mcp.exa.ai/mcp?tools=web_search_exa,web_fetch_exa,web_search_advanced_exa",
                        "headers": {
                                "x-api-key": "{env:EXA_API_KEY}",
                        },
                        "enabled": true,
                        "timeout": 10000,
                },
        },
}
