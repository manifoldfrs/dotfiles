{
    "toolbar": {
        "code_actions": false
    },
    "indent_guides": {
        "background_coloring": "disabled",
        "coloring": "indent_aware"
    },
    "vim": {
        "toggle_relative_line_numbers": true
    },
    "prettier": {
        "allowed": true
    },
    "agent": {
        "show_turn_stats": true,
        "default_model": {
            "provider": "zed.dev",
            "model": "claude-opus-4-6",
            "enable_thinking": true,
            "effort": "high",
        },
        "favorite_models": [],
        "model_parameters": [],
    },
    "auto_install_extensions": {
        "basher": true,
        "biome": true,
        "catppuccin-icons": true,
        "csv": true,
        "dockerfile": true,
        "ghostty": true,
        "golangci-lint": true,
        "html": true,
        "lua": true,
        "make": true,
        "one-dark-pro-enhanced": true,
        "opencode": true,
        "powershell": true,
        "proto": true,
        "sql": true,
        "toml": true,
        "xml": true,
    },
    "diagnostics": {
        "inline": {
            "enabled": true,
            "max_severity": null,
        },
    },
    "icon_theme": "Catppuccin Macchiato",
    "theme": "One Dark Pro",
    "session": {
        "trust_all_worktrees": true,
    },
    "vim_mode": true,
    "terminal": {
        "shell": "system",
        "font_size": 14.0,
        "font_family": "JetBrainsMonoNL Nerd Font",
    },
    "preview_tabs": {
        "enabled": false,
        "enable_preview_from_file_finder": false,
    },
    "tab_bar": {
        "show": true,
    },
    "relative_line_numbers": "enabled",
    "gutter": {
        "line_numbers": true,
    },
    "buffer_font_size": 14.0,
    "buffer_font_family": "JetBrainsMonoNL Nerd Font",
    "colorize_brackets": true,
    "show_edit_predictions": true,
    "semantic_tokens": "combined",
    "ensure_final_newline_on_save": true,
    "soft_wrap": "none",
    "hard_tabs": false,
    "tab_size": 4,
    "base_keymap": "Cursor",
    "context_servers": {},
}
