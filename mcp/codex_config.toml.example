model = "gpt-5.1-codex-max"
model_reasoning_effort = "xhigh"
tool_output_token_limit = 25000

# Add trusted project paths after installation:
# [projects."/Users/YOUR_USERNAME/github"]
# trust_level = "trusted"

[mcp_servers.RepoPromptCE]
command = "/Applications/RepoPrompt CE.app/Contents/MacOS/repoprompt-mcp"
args = []
tool_timeout_sec = 1000
enabled = true

[mcp_servers.Ref]
type = "http"
url = "https://api.ref.tools/mcp"
env_http_headers = { "x-ref-api-key" = "REF_API_KEY" }
enabled = true

[mcp_servers.exa]
type = "http"
url = "https://mcp.exa.ai/mcp?tools=web_search_exa,web_fetch_exa,web_search_advanced_exa"
env_http_headers = { "x-api-key" = "EXA_API_KEY" }
enabled = true
